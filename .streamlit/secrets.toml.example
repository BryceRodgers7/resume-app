# Copy this file to secrets.toml and fill in your actual values for local dev.
# DO NOT commit secrets.toml to version control — it is in .gitignore.
#
# In production these are set as Fly.io secrets (see DEPLOYMENT.md).
# The application reads them via os.getenv(...), so they must be exported
# into the process environment for local runs (e.g. via python-dotenv or
# your launch configuration).

# --- Required ---

# OpenAI — support agent, pirate chatbot, vector-store embeddings
OPENAI_API_KEY = "sk-..."

# Supabase PostgreSQL connection string (full psycopg2 DSN)
SUPADATABASE_URL = "postgresql://user:password@host:port/database"

# Qdrant Cloud vector database
QDRANT_URL = "https://your-cluster.qdrant.io"
QDRANT_API_KEY = "..."

# --- Optional (page-specific; missing values just disable that page's feature) ---

# Stability AI (text-to-image page)
STABILITY_KEY = "sk-..."

# Cloud Run inference services
BRYCEGPT_API_URL = "https://your-gpt-service.run.app"
BPSIMGCLSS_API_URL = "https://your-classifier-service.run.app"

# --- Optional tuning ---

# LOG_LEVEL = "INFO"             # DEBUG / INFO / WARNING / ERROR
# BPSIMGCLSS_TIMEOUT = "120"     # image-classifier read-timeout (seconds)
